{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "description": "Up-to-date library documentation"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub repository management, PRs, issues"
    },
    "shelly-api-docs": {
      "type": "url",
      "url": "https://shelly-api-docs.mcp.shelly.link/mcp"
    },
    "shelly-docker-custom": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e", "SHELLY_API_KEY=${SHELLY_API_KEY}",
        "mslavov/shelly-mcp:latest"
      ]
    },
    "home-assistant": {
      "command": "/Users/phschw/.local/bin/uvx",
      "args": ["--python", "3.13", "ha-mcp@latest"],
      "env": {
        "HOMEASSISTANT_URL": "http://192.168.11.117:8123",
        "HOMEASSISTANT_TOKEN": "${HASS_TOKEN}"
      },
      "description": "Home Assistant control, automations, dashboards (ha-mcp)"
    }
  }
}